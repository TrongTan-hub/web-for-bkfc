# ── BK TUYỂN SINH RAG – CẤU HÌNH MÔI TRƯỜNG ──────────────────────────────────
# Sao chép file này thành .env và điền giá trị thật

# Groq API Key – Lấy miễn phí tại https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# API Key bảo vệ trang Admin Panel
# Đặt chuỗi ngẫu nhiên đủ dài (ít nhất 16 ký tự)
ADMIN_API_KEY=bkfc_admin_change_me_2026

# Cổng server (mặc định 8000)
PORT=8000

# Môi trường: development | production
ENV=development
