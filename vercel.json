{
  "public": true,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/home", "destination": "/frontend/page1_landing/index.html" },
    { "source": "/form", "destination": "/frontend/page2_form/index.html" },
    { "source": "/result", "destination": "/frontend/page3_result/index.html" },
    { "source": "/chat", "destination": "/frontend/page4_chat/index.html" },
    { "source": "/admin/(.*)", "destination": "/frontend/admin/$1" },
    { "source": "/", "destination": "/frontend/admin/index.html" }
  ]
}
