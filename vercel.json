{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ttan-3126-web-for-bkfc.hf.space/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "/frontend/admin/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/page1_landing/index.html"
    },
    {
      "source": "/(style.css|script.js|main.js|.*\\.png|.*\\.jpg|.*\\.svg)",
      "destination": "/frontend/page1_landing/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/page1_landing/$1"
    }
  ]
}
