{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ttan-3126-web-for-bkfc.hf.space/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "/frontend/admin/:path*"
    },
    {
      "source": "/home/:path*",
      "destination": "/frontend/page1_landing/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/frontend/logo/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/page1_landing/index.html"
    }
  ]
}
